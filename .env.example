# Runtime secrets and local environment template.
# Copy to .env.local and replace placeholders with real values.

JWT_SECRET=replace-with-base64-jwt-secret

BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_NET_ID=ADMIN
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password

POSTGRES_USER=hr
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=hr_auth

AUTH_DB_URL=jdbc:postgresql://localhost:5432/hr_auth
AUTH_DB_USERNAME=hr
AUTH_DB_PASSWORD=replace-with-strong-postgres-password

USER_DB_URL=jdbc:postgresql://localhost:5432/hr_user
USER_DB_USERNAME=hr
USER_DB_PASSWORD=replace-with-strong-postgres-password

CONTRACT_DB_URL=jdbc:postgresql://localhost:5432/hr_contract
CONTRACT_DB_USERNAME=hr
CONTRACT_DB_PASSWORD=replace-with-strong-postgres-password

REQUEST_DB_URL=jdbc:postgresql://localhost:5432/hr_request
REQUEST_DB_USERNAME=hr
REQUEST_DB_PASSWORD=replace-with-strong-postgres-password

NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5432/hr_notification
NOTIFICATION_DB_USERNAME=hr
NOTIFICATION_DB_PASSWORD=replace-with-strong-postgres-password

MAIL_USERNAME=replace-with-mail-username
MAIL_PASSWORD=replace-with-mail-password
